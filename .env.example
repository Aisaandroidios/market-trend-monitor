# Server
PORT=8787
HOST=0.0.0.0

# Telegram
# BotFather token. Do not commit your real token.
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
# Telegram supergroup chat id, usually starts with -100.
TELEGRAM_CHAT_ID=replace-with-your-telegram-chat-id
# Topic map: symbol -> message_thread_id.
TELEGRAM_TOPIC_MAP={"BTCUSDT":1,"ETHUSDT":2,"QQQUSDT":3}
TELEGRAM_POLL_INTERVAL_MS=3000

# Optional Lark webhook
LARK_WEBHOOK_URL=

# Optional free news/data keys
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FINNHUB_WEBHOOK_SECRET=
NEWS_TIMEOUT_MS=1200
NEWS_CACHE_TTL_MS=3600000

# Market universe / data fallbacks
ACTIVE_CRYPTO_LIMIT=8
BINANCE_KLINE_CONCURRENCY=8
BINANCE_FUTURES_BASE_URLS=https://fapi.binance.com,https://fapi1.binance.com,https://fapi2.binance.com,https://fapi3.binance.com,https://fapi4.binance.com
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info

# Scheduled full pushes, US Eastern market aware
US_MARKET_AWARE_DECISION_SCHEDULE=true
US_MARKET_REGULAR_DECISION_INTERVAL_MS=900000
US_MARKET_NEAR_OPEN_DECISION_INTERVAL_MS=1800000
US_MARKET_PREMARKET_DECISION_INTERVAL_MS=3600000
US_MARKET_AFTER_HOURS_DECISION_INTERVAL_MS=3600000
US_MARKET_OFF_HOURS_DECISION_INTERVAL_MS=14400000
US_MARKET_WEEKEND_DECISION_INTERVAL_MS=14400000
DECISION_WARMUP_MS=15000

# Opportunity scans, lower-cost alert loop
OPPORTUNITY_SCAN_ENABLED=true
OPPORTUNITY_SCAN_REGULAR_INTERVAL_MS=300000
OPPORTUNITY_SCAN_NEAR_OPEN_INTERVAL_MS=600000
OPPORTUNITY_SCAN_PREMARKET_INTERVAL_MS=900000
OPPORTUNITY_SCAN_AFTER_HOURS_INTERVAL_MS=1800000
OPPORTUNITY_SCAN_OFF_HOURS_INTERVAL_MS=3600000
OPPORTUNITY_SCAN_WEEKEND_INTERVAL_MS=3600000
OPPORTUNITY_ALERT_COOLDOWN_MS=1800000

# Optional Python model/data brain
PYTHON_MODEL_BRAIN_ENABLED=true
MODEL_BRAIN_PYTHON=.venv/bin/python
PYTHON_MODEL_BRAIN_TIMEOUT_MS=8000
MODEL_BRAIN_SIGNALS_PATH=data/model-signals.json

# Optional TradingView adapter. Keep disabled unless tvDatafeed is installed.
TRADINGVIEW_DATA_ENABLED=false
TRADINGVIEW_PYTHON=.venv/bin/python
TRADINGVIEW_DATA_TIMEOUT_MS=5000

# Free Yahoo Finance OHLC fallback for stocks/ETFs/commodities.
YAHOO_DATA_ENABLED=true
YAHOO_PYTHON=.venv/bin/python
YAHOO_DATA_TIMEOUT_MS=12000
