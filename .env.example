# Server
PORT=8787
HOST=0.0.0.0

# Telegram
# BotFather token. Do not commit your real token.
TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
# Telegram supergroup chat id, usually starts with -100.
TELEGRAM_CHAT_ID=replace-with-your-telegram-chat-id
# Topic map: symbol -> message_thread_id.
TELEGRAM_TOPIC_MAP={"BTCUSDT":1,"ETHUSDT":2,"QQQUSDT":3}
TELEGRAM_POLL_INTERVAL_MS=3000
# Paper account / position updates go to one dedicated Telegram Topic.
PAPER_ACCOUNT_TOPIC_ID=2597
PAPER_DAILY_SUMMARY_ENABLED=true
PAPER_DAILY_SUMMARY_TIME=08:30
# Strategy attribution updates go to one dedicated Telegram Topic.
STRATEGY_ATTRIBUTION_TOPIC_ID=2679
# Probability calibration updates go to one dedicated Telegram Topic.
PROBABILITY_CALIBRATION_TOPIC_ID=2683

# Optional Lark webhook
LARK_WEBHOOK_URL=

# Master switch for Telegram/Lark sending. Set false while verifying locally.
NOTIFICATION_SEND_ENABLED=true

# Optional free news/data keys
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FINNHUB_WEBHOOK_SECRET=
TWELVE_DATA_API_KEY=
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_DATA_FEED=iex
NEWS_TIMEOUT_MS=1200
NEWS_CACHE_TTL_MS=3600000

# Market universe / data fallbacks
ACTIVE_CRYPTO_LIMIT=8
BINANCE_KLINE_CONCURRENCY=8
BINANCE_FUTURES_BASE_URLS=https://fapi.binance.com,https://fapi1.binance.com,https://fapi2.binance.com,https://fapi3.binance.com,https://fapi4.binance.com
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info

# Reference candles for US stocks/ETFs/commodities when no exchange contract K-line is available.
# Providers are tried in order; missing keys or failed providers are skipped automatically.
REFERENCE_DATA_PROVIDERS=tradingview,yahoo,alpha_vantage,twelve_data,alpaca,finnhub
REFERENCE_DATA_TIMEOUT_MS=7000

# Derivatives/order-book data used as signal factors only. No funding-fee accounting.
DERIVATIVES_DATA_ENABLED=true
DERIVATIVES_DATA_LIMIT=20
DERIVATIVES_DATA_CONCURRENCY=4

# Data storage. auto uses local SQLite when node:sqlite is available, otherwise JSON/JSONL files.
DATA_STORE=auto
SQLITE_DB_PATH=data/market-monitor.sqlite

# Scheduled full pushes, US Eastern market aware
US_MARKET_AWARE_DECISION_SCHEDULE=true
US_MARKET_REGULAR_DECISION_INTERVAL_MS=900000
US_MARKET_NEAR_OPEN_DECISION_INTERVAL_MS=1800000
US_MARKET_PREMARKET_DECISION_INTERVAL_MS=3600000
US_MARKET_AFTER_HOURS_DECISION_INTERVAL_MS=3600000
US_MARKET_OFF_HOURS_DECISION_INTERVAL_MS=14400000
US_MARKET_WEEKEND_DECISION_INTERVAL_MS=14400000
DECISION_WARMUP_MS=15000

# Opportunity scans, lower-cost alert loop
OPPORTUNITY_SCAN_ENABLED=true
OPPORTUNITY_SCAN_REGULAR_INTERVAL_MS=225000
OPPORTUNITY_SCAN_NEAR_OPEN_INTERVAL_MS=450000
OPPORTUNITY_SCAN_PREMARKET_INTERVAL_MS=900000
OPPORTUNITY_SCAN_AFTER_HOURS_INTERVAL_MS=900000
OPPORTUNITY_SCAN_OFF_HOURS_INTERVAL_MS=3600000
OPPORTUNITY_SCAN_WEEKEND_INTERVAL_MS=3600000
OPPORTUNITY_ALERT_COOLDOWN_MS=1800000

# Simulated live account. This never places real orders.
PAPER_TRADING_ENABLED=true
PAPER_INITIAL_BALANCE=10000
PAPER_RISK_PER_TRADE=0.02
PAPER_MAX_NOTIONAL_PCT=1
PAPER_MAX_OPEN_POSITIONS=6
PAPER_MIN_CONVICTION=68
PAPER_MIN_RR=1.3
PAPER_MIN_CONFIDENCE=MEDIUM
PAPER_MIN_PLAYBOOK_SCORE=0.5
PAPER_ADAPTIVE_THRESHOLDS=true
PAPER_REQUIRE_EXECUTE=false
PAPER_REQUIRE_DATA_SOURCE=true
# Execution costs are intentionally disabled per current strategy requirements.
PAPER_FEE_RATE=0
PAPER_SLIPPAGE_BPS=0
PAPER_ACCOUNT_PATH=data/paper-account.json
PAPER_TRADES_PATH=data/paper-trades.jsonl

# Position risk engine. Ordinary setups stay capped to 0.25%-1%; high-edge setups can use up to 2%.
PAPER_POSITION_RISK_ENABLED=true
PAPER_MIN_RISK_PER_TRADE=0.0025
PAPER_MAX_RISK_PER_TRADE=0.01
PAPER_HIGH_QUALITY_RISK_ENABLED=true
PAPER_HIGH_QUALITY_MAX_RISK_PER_TRADE=0.02
PAPER_HIGH_QUALITY_MIN_CONVICTION=84
PAPER_HIGH_QUALITY_MIN_RR=2.2
PAPER_HIGH_QUALITY_MIN_WIN_PROBABILITY=0.65
PAPER_HIGH_QUALITY_MIN_PLAYBOOK_SCORE=0.75
PAPER_HIGH_QUALITY_MIN_VOLUME_RATIO=1
PAPER_HIGH_QUALITY_MIN_QUOTE_VOLUME_24H=5000000
PAPER_DAILY_MAX_LOSS_PCT=0.03
PAPER_WEEKLY_MAX_LOSS_PCT=0.07
PAPER_MAX_CONSECUTIVE_LOSSES=4
PAPER_LOSS_STREAK_CUT_1=2
PAPER_LOSS_STREAK_CUT_2=3
PAPER_SAME_BUCKET_MAX_POSITIONS=3
PAPER_SAME_BUCKET_MAX_RISK_PCT=0.025
PAPER_HIGH_ATR_PCT=0.055
PAPER_MAX_ATR_PCT=0.12
PAPER_ENGINE_MIN_RR=1.2
# Soft liquidity thresholds reduce size for small accounts; hard quote volume still blocks extreme cases.
PAPER_MIN_QUOTE_VOLUME_24H=5000000
PAPER_LOW_VOLUME_RATIO=0.65
PAPER_HARD_MIN_QUOTE_VOLUME_24H=50000
PAPER_HARD_LOW_VOLUME_RATIO=0.25

# Walk-forward validation. Uses past train windows to select params, then validates on later windows.
WALK_FORWARD_ENABLED=true
WALK_FORWARD_TRAIN_WINDOW=84
WALK_FORWARD_TEST_WINDOW=24
WALK_FORWARD_STEP_WINDOW=24

# Probability calibration. Compares predicted win-probability buckets with reviewed outcomes.
PROBABILITY_CALIBRATION_BUCKET_SIZE=5
PROBABILITY_CALIBRATION_MIN_BUCKET_SAMPLES=4
PROBABILITY_CALIBRATION_MIN_TOTAL_SAMPLES=6

# Free event-risk gate. Optional JSON windows can block/reduce new signals around macro or earnings events.
EVENT_RISK_ENABLED=true
EVENT_RISK_WINDOWS_JSON=[]

# Optional Python model/data brain
PYTHON_MODEL_BRAIN_ENABLED=true
MODEL_BRAIN_PYTHON=.venv/bin/python
PYTHON_MODEL_BRAIN_TIMEOUT_MS=8000
MODEL_BRAIN_SIGNALS_PATH=data/model-signals.json

# Optional TradingView adapter. Keep disabled unless tvDatafeed is installed.
TRADINGVIEW_DATA_ENABLED=false
TRADINGVIEW_PYTHON=.venv/bin/python
TRADINGVIEW_DATA_TIMEOUT_MS=5000

# Free Yahoo Finance OHLC fallback for stocks/ETFs/commodities.
YAHOO_DATA_ENABLED=true
YAHOO_PYTHON=.venv/bin/python
YAHOO_DATA_TIMEOUT_MS=12000
